        "type": [
          {
            "code": "instant"
          }
        ]
      },
      {
        "id": "Observation.method",
        "path": "Observation.method",
        "short": "Messverfahren",
        "definition": "Das Messverfahren (z. B. Sensorik, Teststreifen).",
        "max": "1",
        "type": [
          {
            "code": "CodeableConcept"
          }
        ]
      },
      {
        "id": "Observation.note",
        "path": "Observation.note",
        "short": "Notiz oder Annotation",
        "definition": "Zusätzliche Anmerkungen zur Messung.",
        "type": [
          {
            "code": "Annotation"
          }
        ]
      }
