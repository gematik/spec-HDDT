  "publisher": "gematik GmbH",
  "description": "Profile für die Erfassung einer CGM-Messreihe (Gewebezucker) als Observation mit SampledData.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Observation",
