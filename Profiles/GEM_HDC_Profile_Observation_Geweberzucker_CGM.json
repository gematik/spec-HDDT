        "type": [
          {
            "code": "SampledData"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Observation.value[x].origin.unit",
        "path": "Observation.value[x].origin.unit",
        "min": 1
      },
      {
        "id": "Observation.value[x].origin.system",
        "path": "Observation.value[x].origin.system",
        "min": 1
      },
      {
        "id": "Observation.value[x].origin.code",
        "path": "Observation.value[x].origin.code",
        "short": "Code der Messeinheit",
        "definition": "UCUM-Code der Messeinheit.",
        "min": 1,
        "binding": {
          "strength": "required",
          "valueSet": "https://gematik.de/fhir/hdc/ValueSet/VS_Blutzucker_Einheiten"
        }
      },
      {
        "id": "Observation.device",
        "path": "Observation.device",
        "short": "Gerätekonfiguration",
        "definition": "Verweis auf die DeviceMetric-Ressource der Konfiguration.",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://gematik.de/fhir/hdc/StructureDefinition/DeviceMetric-CGM"
            ]
          }
        ]
      },
      {
        "id": "Observation.referenceRange.low",
        "path": "Observation.referenceRange.low",
        "short": "Referenzbereich – Untere Grenze",
        "definition": "Niedrigster Normalwert."
      },
      {
        "id": "Observation.referenceRange.high",
        "path": "Observation.referenceRange.high",
        "short": "Referenzbereich – Obere Grenze",
        "definition": "Höchster Normalwert."
      },
      {
        "id": "Observation.issued",
        "path": "Observation.issued",
        "short": "Zeit der Erfassung",
        "definition": "Zeitpunkt, zu dem die Messung im System erfasst wurde.",
