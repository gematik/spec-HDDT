  fhir:concept ( [
     fhir:code [ fhir:v "personal-best" ] ;
     fhir:display [ fhir:v "Personal Best" ] ;
     fhir:definition [ fhir:v "Reference value based on the personal best value achieved by the patient within a certain time frame." ]
  ] [
     fhir:code [ fhir:v "GLI-2012" ] ;
     fhir:display [ fhir:v "Predicted Value according to Global Lung Initiative 2012" ] ;
     fhir:definition [ fhir:v "Reference value calculated based on the Global Lung Initiative 2012 equations. I.e the patient's 'race' is considered." ]
  ] [
     fhir:code [ fhir:v "GLI-2022" ] ;
     fhir:display [ fhir:v "Predicted Value according to Global Lung Initiative 2022" ] ;
     fhir:definition [ fhir:v "Reference value calculated based on the Global Lung Initiative 2022 equations. I.e. a 'race'-neutral approach is used." ]
  ] [
     fhir:code [ fhir:v "other" ] ;
     fhir:display [ fhir:v "Other" ] ;
     fhir:definition [ fhir:v "Other method used to determine the lung function reference value. Specify details via text input." ]
  ] ) . # 

