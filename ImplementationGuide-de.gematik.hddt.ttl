       ] ;
       fhir:name [ fhir:v "HDDT Blood Pressure DeviceMetric Example" ] ;
       fhir:description [ fhir:v "Example of a __DeviceMetric for blood pressure measurements__ from a blood pressure cuff:\nThe device measures the blood pressure in mmHg from the patient using an oscillometric method.\nThe device is calibrated by the manufacturer and does not require user calibration." ] ;
