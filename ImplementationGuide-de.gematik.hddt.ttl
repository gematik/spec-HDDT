       ] ;
       fhir:name [ fhir:v "HL7 CGM Summary: Days of Wear Example" ] ;
       fhir:description [ fhir:v "This example is an instance of the Days of Wear profile. It represents a summary observation of the number of days a Continuous Glucose Monitoring (CGM) device was worn by the patient over the period from May 1, 2024, to May 31, 2024, with a final recorded value of 28 days." ] ;
       fhir:example [
