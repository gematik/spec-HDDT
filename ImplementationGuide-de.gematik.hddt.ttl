         fhir:reference [ fhir:v "DeviceDefinition/device-definition-blood-pressure-cuff-001" ]
       ] ;
       fhir:name [ fhir:v "HDDT Blood Pressure Cuff DeviceDefinition Example" ] ;
       fhir:description [ fhir:v "This example represents a Blood Pressure Cuff device definition from the HIIS-VZ." ] ;
       fhir:example [
