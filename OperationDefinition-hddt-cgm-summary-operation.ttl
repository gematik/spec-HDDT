  fhir:version [ fhir:v "1.0.1"] ; # 
  fhir:name [ fhir:v "HddtCgmSummaryOperation"] ; # 
  fhir:title [ fhir:v "Search Operation for summary data measurement"] ; # 
  fhir:status [ fhir:v "active"] ; # 
