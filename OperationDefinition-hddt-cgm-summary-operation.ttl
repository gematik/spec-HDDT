     fhir:type [ fhir:v "dateTime" ]
  ] [
     fhir:name [ fhir:v "related" ] ;
     fhir:use [ fhir:v "in" ] ;
     fhir:min [ fhir:v 0 ] ;
     fhir:max [ fhir:v "1" ] ;
     fhir:documentation [ fhir:v "If true, include related Device and DeviceMetric in the result bundle" ] ;
     fhir:type [ fhir:v "boolean" ]
  ] [
     fhir:name [ fhir:v "result" ] ;
