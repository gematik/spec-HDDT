{
  "resourceType": "StructureDefinition",
  "id": "Observation-CGM-Measurement-Series",
  "url": "https://gematik.de/fhir/hdc/StructureDefinition/Observation-CGM-Measurement-Series",
  "version": "0.1.0",
  "name": "Observation_CGM_Measurement_Series",
  "title": "Observation – Tissue Glucose (CGM Measurement Series)",
  "status": "draft",
  "date": "2025-08-12",
  "publisher": "gematik GmbH",
  "description": "Profile for capturing a CGM measurement time series (tissue glucose) as Observation.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Observation",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Observation",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Observation.code",
        "path": "Observation.code",
        "short": "Type of measurement",
        "definition": "Coding of this measurement, e.g., tissue glucose from LOINC.",
        "binding": {
          "strength": "required",
          "description": "Specifies the type of measurement using codes from the ValueSet for tissue glucose measurements.",
          "valueSet": "https://gematik.de/fhir/hdc/ValueSet/VS-Tissue-Glucose-CGM"
        }
      },
      {
        "id": "Observation.subject",
        "path": "Observation.subject",
        "short": "Patient subject",
        "definition": "Reference to the patient to whom this time series belongs.",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/StructureDefinition/Patient"
            ]
          }
        ]
      },
      {
        "id": "Observation.effective[x]",
        "path": "Observation.effective[x]",
        "short": "Measurement time point or period",
        "definition": "The time or period when the CGM measurement was taken.",
        "min": 1,
        "type": [
          {
            "code": "Period"
          }
        ]
      },
      {
        "id": "Observation.effective[x].start",
        "path": "Observation.effective[x].start",
        "short": "Start of measurement period",
        "definition": "The starting time of the CGM measurement period.",
        "min": 1
      },
      {
        "id": "Observation.effective[x].end",
        "path": "Observation.effective[x].end",
        "short": "End of measurement period",
        "definition": "The ending time of the CGM measurement period.",
        "min": 1
      },
      {
        "id": "Observation.value[x]",
        "path": "Observation.value[x]",
        "short": "Time series",
        "definition": "CGM time series as a SampledData object.",
        "min": 1,
        "type": [
          {
            "code": "SampledData"
          }
        ]
      },
      {
        "id": "Observation.value[x].origin.unit",
        "path": "Observation.value[x].origin.unit",
        "short": "Unit of measurement",
        "definition": "The unit of measurement for the origin of the SampledData.",
        "min": 1
      },
      {
        "id": "Observation.value[x].origin.system",
        "path": "Observation.value[x].origin.system",
        "short": "System of measurement",
        "definition": "The system of measurement for the origin of the SampledData.",
        "min": 1,
        "fixedUri": "http://unitsofmeasure.org"
      },
      {
        "id": "Observation.value[x].origin.code",
        "path": "Observation.value[x].origin.code",
        "short": "Code of measurement unit",
        "definition": "The code representing the unit of measurement for the origin of the SampledData.",
        "min": 1,
        "binding": {
          "strength": "required",
          "description": "Defines the unit of measurement using codes from the ValueSet for blood glucose units (UCUM code).",
          "valueSet": "https://gematik.de/fhir/hdc/ValueSet/VS-Blood-Glucose-Units"
        }
      },
      {
        "id": "Observation.value[x].data",
        "path": "Observation.value[x].data",
        "min": 1
      },
      {
        "id": "Observation.note",
        "path": "Observation.note",
        "short": "Comments about the measurement",
        "definition": "Additional comments on the measurement."
      },
      {
        "id": "Observation.method",
        "path": "Observation.method",
        "short": "Measurement method",
        "definition": "The measurement method (e.g., sensor technology).",
        "mustSupport": true
      },
      {
        "id": "Observation.device",
        "path": "Observation.device",
        "short": "Device configuration",
        "definition": "Reference to the DeviceMetric resource of the configuration.",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://gematik.de/fhir/hdc/StructureDefinition/DeviceMetric-Medical-Aid"
            ]
          }
        ]
      },
      {
        "id": "Observation.referenceRange",
        "path": "Observation.referenceRange",
        "mustSupport": true
      },
      {
        "id": "Observation.referenceRange.low",
        "path": "Observation.referenceRange.low",
        "short": "Reference range – Lower limit",
        "definition": "Lowest normal value."
      },
      {
        "id": "Observation.referenceRange.low.value",
        "path": "Observation.referenceRange.low.value",
        "min": 1
      },
      {
        "id": "Observation.referenceRange.low.unit",
        "path": "Observation.referenceRange.low.unit",
        "min": 1
      },
      {
        "id": "Observation.referenceRange.low.system",
        "path": "Observation.referenceRange.low.system",
        "min": 1,
        "fixedUri": "http://unitsofmeasure.org"
      },
      {
        "id": "Observation.referenceRange.low.code",
        "path": "Observation.referenceRange.low.code",
        "min": 1,
        "binding": {
          "strength": "required",
          "description": "Defines the unit of measurement using codes from the ValueSet for blood glucose units (UCUM code).",
          "valueSet": "https://gematik.de/fhir/hdc/ValueSet/VS-Blood-Glucose-Units"
        }
      },
      {
        "id": "Observation.referenceRange.high",
        "path": "Observation.referenceRange.high",
        "short": "Reference range – Upper limit",
        "definition": "Highest normal value."
      },
      {
        "id": "Observation.referenceRange.high.value",
        "path": "Observation.referenceRange.high.value",
        "min": 1
      },
      {
        "id": "Observation.referenceRange.high.unit",
        "path": "Observation.referenceRange.high.unit",
        "min": 1
      },
      {
        "id": "Observation.referenceRange.high.system",
        "path": "Observation.referenceRange.high.system",
        "min": 1,
        "fixedUri": "http://unitsofmeasure.org"
      },
      {
        "id": "Observation.referenceRange.high.code",
        "path": "Observation.referenceRange.high.code",
        "min": 1,
        "binding": {
          "strength": "required",
          "description": "Defines the unit of measurement using codes from the ValueSet for blood glucose units (UCUM code).",
          "valueSet": "https://gematik.de/fhir/hdc/ValueSet/VS-Blood-Glucose-Units"
        }
      }
    ]
  }
}