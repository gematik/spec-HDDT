' ===== Palette =====
!define COL_BG           DFEBF0
!define COL_TEXT         111111
!define COL_BORDER       95A4A8
!define COL_TEAL         5E9BB1
!define COL_LIGHT_TEAL   A0C5CF
!define COL_DARK_TEAL    0F2A33
!define COL_RASPBERRY    BA2C4C
!define COL_RASPBERRY_MD C85670

' ===== Global look =====
skinparam backgroundColor #COL_BG
skinparam shadowing false
skinparam dpi 150
skinparam RoundCorner 18
skinparam DefaultFontColor #COL_TEXT
skinparam ArrowThickness 2
skinparam ArrowColor #COL_TEAL

' ===== Objects (for object diagrams) =====
skinparam object {
  BackgroundColor white
  BorderColor #COL_BORDER
  LineThickness 1.2
  FontColor #COL_TEXT
  StereotypeFontColor #COL_BORDER
}

' ===== Generic rectangles (matches your boxes) =====
skinparam rectangle {
  BorderColor #COL_BORDER
  LineThickness 1.2
  FontColor #COL_TEXT
}

' Personal Device (teal-blue)
skinparam rectangle<<Personal Device>> {
  BackgroundColor #COL_TEAL
  BorderColor #COL_TEAL
  FontColor white
  StereotypeFontColor white
  RoundCorner 20
  LineThickness 1.5
}

' Configuration (light teal)
skinparam rectangle<<Configuration>> {
  BackgroundColor #COL_LIGHT_TEAL
  BorderColor #COL_LIGHT_TEAL
  FontColor #COL_DARK_TEAL
  RoundCorner 16
}

' Measured data (deep raspberry)
skinparam rectangle<<measured data>> {
  BackgroundColor #COL_RASPBERRY
  BorderColor #COL_RASPBERRY
  FontColor white
  RoundCorner 22
  LineThickness 1.5
}

' Derived data (mid raspberry)
skinparam rectangle<<derived data>> {
  BackgroundColor #COL_RASPBERRY_MD
  BorderColor #COL_RASPBERRY_MD
  FontColor white
  RoundCorner 18
}

' Domain box (white with teal border)
skinparam rectangle<<Domain>> {
  BackgroundColor white
  BorderColor #COL_TEAL
  LineThickness 2.2
  FontColor #COL_TEXT
  RoundCorner 10
}

' Neutral helper
skinparam rectangle<<neutral>> {
  BackgroundColor #COL_BG
  BorderColor #COL_BORDER
  LineThickness 1
  FontColor #COL_TEXT
}

' ===== Sequence-diagram tuning (for your pairing flow) =====
skinparam Sequence {
  BorderColor #COL_BORDER
  ArrowColor  #COL_TEAL

  LifeLineBorderColor #COL_BORDER
  LifeLineBackgroundColor #COL_BG

  ParticipantBorderColor #COL_TEAL
  ParticipantBackgroundColor #COL_TEAL
  ParticipantFontColor white

  ActorBorderColor #COL_TEAL
  ActorBackgroundColor #COL_LIGHT_TEAL
  ActorFontColor #COL_DARK_TEAL

  ' activation bars
  ActivationBarColor #COL_RASPBERRY_MD
  ActivationBarBorderColor #COL_RASPBERRY_MD

  ' groups (==, alt, etc.)
  GroupBorderColor #COL_TEAL
  GroupBackgroundColor #COL_LIGHT_TEAL
  GroupFontColor #COL_DARK_TEAL

  ' references
  ReferenceBorderColor #COL_TEAL
  ReferenceBackgroundColor #COL_LIGHT_TEAL
  ReferenceFontColor #COL_DARK_TEAL

  ' notes / dividers
  NoteBackgroundColor #COL_RASPBERRY
  NoteBorderColor #COL_RASPBERRY
  NoteFontColor white

  DividerBorderColor #COL_RASPBERRY_MD
  DividerBackgroundColor #COL_BG
  DividerFontColor #COL_RASPBERRY_MD
}

' ===== Title frame (red style, rounded, white text) =====
skinparam titleFontColor white
skinparam titleBackgroundColor #COL_RASPBERRY_MD
skinparam titleBorderColor #COL_RASPBERRY_MD
skinparam titleBorderThickness 0
skinparam titleBorderRoundCorner 18
skinparam titleFontSize 18
