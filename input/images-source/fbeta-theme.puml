' ===== Global look =====
skinparam backgroundColor #DFEBF0
skinparam shadowing false
skinparam dpi 150
skinparam RoundCorner 18
skinparam DefaultFontColor #111111
skinparam ArrowThickness 2
skinparam ArrowColor #5E9BB1

' ===== Generic rectangles (matches your boxes) =====
skinparam rectangle {
  BorderColor #95A4A8
  LineThickness 1.2
  FontColor #111111
}

' Personal Device (teal-blue)
skinparam rectangle<<Personal Device>> {
  BackgroundColor #5E9BB1
  BorderColor #5E9BB1
  FontColor white
  StereotypeFontColor white
  RoundCorner 20
  LineThickness 1.5
}

' Configuration (light teal)
skinparam rectangle<<Configuration>> {
  BackgroundColor #A0C5CF
  BorderColor #A0C5CF
  FontColor #0F2A33
  RoundCorner 16
}

' Measured data (deep raspberry)
skinparam rectangle<<measured data>> {
  BackgroundColor #BA2C4C
  BorderColor #BA2C4C
  FontColor white
  RoundCorner 22
  LineThickness 1.5
}

' Derived data (mid raspberry)
skinparam rectangle<<derived data>> {
  BackgroundColor #C85670
  BorderColor #C85670
  FontColor white
  RoundCorner 18
}

' Domain box (white with teal border)
skinparam rectangle<<Domain>> {
  BackgroundColor white
  BorderColor #5E9BB1
  LineThickness 2.2
  FontColor #111111
  RoundCorner 10
}

' Neutral helper
skinparam rectangle<<neutral>> {
  BackgroundColor #DFEBF0
  BorderColor #95A4A8
  LineThickness 1
  FontColor #111111
}

' ===== Sequence-diagram tuning (for your pairing flow) =====
skinparam Sequence {
  BorderColor #95A4A8
  ArrowColor  #5E9BB1

  LifeLineBorderColor #95A4A8
  LifeLineBackgroundColor #DFEBF0

  ParticipantBorderColor #5E9BB1
  ParticipantBackgroundColor #5E9BB1
  ParticipantFontColor white

  ActorBorderColor #5E9BB1
  ActorBackgroundColor #A0C5CF
  ActorFontColor #0F2A33

  ' activation bars
  ActivationBarColor #C85670
  ActivationBarBorderColor #C85670

  ' groups (==, alt, etc.)
  GroupBorderColor #5E9BB1
  GroupBackgroundColor #A0C5CF
  GroupFontColor #0F2A33

  ' references
  ReferenceBorderColor #5E9BB1
  ReferenceBackgroundColor #A0C5CF
  ReferenceFontColor #0F2A33

  ' notes / dividers
  NoteBackgroundColor #BA2C4C
  NoteBorderColor #BA2C4C
  NoteFontColor white

  DividerBorderColor #95A4A8
  DividerBackgroundColor #DFEBF0
  DividerFontColor #95A4A8
}

' ===== Title frame (red style, rounded, white text) =====
skinparam titleFontColor white
skinparam titleBackgroundColor #C85670
skinparam titleBorderColor #C85670
skinparam titleBorderThickness 0
skinparam titleBorderRoundCorner 18
skinparam titleFontSize 20
