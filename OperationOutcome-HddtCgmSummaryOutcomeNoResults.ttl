# - resource -------------------------------------------------------------------

<https://gematik.de/fhir/hddt/OperationOutcome/HddtCgmSummaryOutcomeNoResults> a fhir:OperationOutcome ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "HddtCgmSummaryOutcomeNoResults"] ; # 
  fhir:issue ( [
     fhir:severity [ fhir:v "information" ] ;
     fhir:code [ fhir:v "not-found" ] ;
     fhir:details [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/operation-outcome"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/operation-outcome>
         ] ;
         fhir:code [ fhir:v "MSG_NO_MATCH" ]
       ] ) ;
       fhir:text [ fhir:v "No CGM summary observations found for the given effective period." ]
     ]
  ] ) . # 

