# - resource -------------------------------------------------------------------

<https://gematik.de/fhir/hddt/DeviceDefinition/example-universal-backend> a fhir:DeviceDefinition ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "example-universal-backend"] ; # 
  fhir:extension ( [
     fhir:url [
       fhir:v "https://fhir.bfarm.de/StructureDefinition/HiisDeviceDataRecorderEndpointLink"^^xsd:anyURI ;
       fhir:l <https://fhir.bfarm.de/StructureDefinition/HiisDeviceDataRecorderEndpointLink>
     ] ;
     fhir:value [
       a fhir:Reference ;
       fhir:l <https://gematik.de/fhir/hddt/Endpoint/example-universal-endpoint-fhir> ;
       fhir:reference [ fhir:v "Endpoint/example-universal-endpoint-fhir" ]
     ]
  ] [
     fhir:url [
       fhir:v "https://fhir.bfarm.de/StructureDefinition/HiisDeviceDataRecorderEndpointLink"^^xsd:anyURI ;
       fhir:l <https://fhir.bfarm.de/StructureDefinition/HiisDeviceDataRecorderEndpointLink>
     ] ;
     fhir:value [
       a fhir:Reference ;
       fhir:l <https://gematik.de/fhir/hddt/Endpoint/example-universal-endpoint-auth> ;
       fhir:reference [ fhir:v "Endpoint/example-universal-endpoint-auth" ]
     ]
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "delayFromRealTime"^^xsd:anyURI ;
         fhir:l fhir:delayFromRealTime
       ] ;
       fhir:value [
         a fhir:Duration ;
         fhir:value [ fhir:v "60"^^xsd:decimal ] ;
         fhir:unit [ fhir:v "s" ]
       ]
     ] [
       fhir:url [
         fhir:v "gracePeriod"^^xsd:anyURI ;
         fhir:l fhir:gracePeriod
       ] ;
       fhir:value [
         a fhir:Duration ;
         fhir:value [ fhir:v "15"^^xsd:decimal ] ;
         fhir:unit [ fhir:v "min" ]
       ]
     ] [
       fhir:url [
         fhir:v "historicDataPeriod"^^xsd:anyURI ;
         fhir:l fhir:historicDataPeriod
       ] ;
       fhir:value [
         a fhir:Duration ;
         fhir:value [ fhir:v "30"^^xsd:decimal ] ;
         fhir:unit [ fhir:v "d" ]
       ]
     ] ) ;
     fhir:url [
       fhir:v "https://fhir.bfarm.de/StructureDefinition/HiisDeviceDefinitionMivSet"^^xsd:anyURI ;
       fhir:l <https://fhir.bfarm.de/StructureDefinition/HiisDeviceDefinitionMivSet>
     ]
  ] ) ; # 
  fhir:identifier ( [
     fhir:system [
       fhir:v "https://fhir.bfarm.de/Identifier/HiisId"^^xsd:anyURI ;
       fhir:l <https://fhir.bfarm.de/Identifier/HiisId>
     ] ;
     fhir:value [ fhir:v "DE-1234567890" ]
  ] ) ; # 
  fhir:manufacturer [
     a fhir:String ;
     fhir:v "Health IT Solutions AG"
  ] ; # 
  fhir:deviceName ( [
     fhir:name [ fhir:v "§ 374a SGB V Universal Backend" ] ;
     fhir:type [ fhir:v "user-friendly-name" ]
  ] ) ; # 
  fhir:version ( [ fhir:v "1.0.1"] ) . # 

